# Copy to .env.local and customize (never commit .env.local).
# Load in shell:  set -a && source .env.local && set +a

# SQLAlchemy / psycopg2 URL for local Docker Postgres (see docker-compose.yml)
DATABASE_URL=postgresql://finance_user:finance_password@127.0.0.1:5432/finance

# OpenClaw gateway container (docker-compose.openclaw.yml) defaults to host.docker.internal
# instead of 127.0.0.1 so Python inside the gateway can reach Postgres published on the host.

# Optional: finance archive root (ledger under 20_ledger/) for imports and analyze_*.py
# FINANCE_ARCHIVE_ROOT=/path/to/finance_archive
